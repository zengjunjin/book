# 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# 数据库配置
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/book_recommend?client_encoding=utf8

# Redis 配置
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 安全配置 - 【重要】生产环境必须设置！
SECRET_KEY=生成一个至少32字符的随机字符串，例如: openssl rand -base64 32

# JWT 配置
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 应用配置
DEBUG=false
APP_NAME=Book Recommendation API
VERSION=2.0.0
